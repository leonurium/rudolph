{
  "version": 2,
  "buildCommand": "npx tsc -p tsconfig.build.json",
  "installCommand": "npm install --include=dev",
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index" }
  ],
  "functions": {
    "api/index.js": {
      "includeFiles": "dist/**",
      "maxDuration": 30
    }
  }
}

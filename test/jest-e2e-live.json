{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testEnvironment": "node",
  "testRegex": "test/app\\.live\\.e2e-spec\\.ts$",
  "setupFiles": ["<rootDir>/test/setup/live-env.ts"],
  "testTimeout": 120000,
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/src/$1"
  }
}
